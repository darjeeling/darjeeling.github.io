# Copy to .env and fill in. `.env` is gitignored - never commit real values.
#   cp .env.example .env

# ---------------------------------------------------------------------------
# Editor server (defaults shown; usually no need to change)
# Prefer `make editor-tailscale` over binding 0.0.0.0 - the editor has no auth.
# ---------------------------------------------------------------------------
#BLOG_EDITOR_HOST=127.0.0.1
#BLOG_EDITOR_PORT=8765

# ---------------------------------------------------------------------------
# AI features (title/tags/slug/summary suggestions, translation, alt text)
# Optional: without a key the editor works, AI actions are disabled.
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
#OPENAI_MODEL=gpt-4.1-mini
#OPENAI_BASE_URL=

# ---------------------------------------------------------------------------
# Encrypted SNS-draft sync via git (apps/editor/drafts/*.age)
# Generate a key and use the SAME key on every device:
#   uv run python -m apps.editor.api.social.sync
# Optional: without a key, drafts stay in the local sqlite only.
# ---------------------------------------------------------------------------
BLOG_EDITOR_DRAFTS_KEY=

# ---------------------------------------------------------------------------
# SNS credentials, keyed by account id from apps/editor/social_accounts.json:
#   BLOG_EDITOR_SNS_{ACCOUNT_ID_UPPER_SNAKE}_{KEY}
# Add/remove blocks to match your accounts file.
# ---------------------------------------------------------------------------

# bluesky-ko: app password from Settings > Privacy and Security > App Passwords
BLOG_EDITOR_SNS_BLUESKY_KO_APP_PASSWORD=

# mastodon-ko: access token from Preferences > Development > New application
# (scopes: write:statuses write:media read:search)
BLOG_EDITOR_SNS_MASTODON_KO_ACCESS_TOKEN=

# threads-ko: Meta developer app with the Threads API product
# (scopes: threads_basic, threads_content_publish)
BLOG_EDITOR_SNS_THREADS_KO_CLIENT_ID=
BLOG_EDITOR_SNS_THREADS_KO_CLIENT_SECRET=
# Optional: HTTPS redirect URI registered in the Meta app
# (default: https://iz4u.net/threads-callback/)
#BLOG_EDITOR_SNS_THREADS_KO_REDIRECT_URI=

# linkedin-en: developer app with "Share on LinkedIn" +
# "Sign In with LinkedIn using OpenID Connect" products.
# Register http://127.0.0.1:8765/api/social/oauth/linkedin/callback in the app.
BLOG_EDITOR_SNS_LINKEDIN_EN_CLIENT_ID=
BLOG_EDITOR_SNS_LINKEDIN_EN_CLIENT_SECRET=
# Optional: override when authorizing from another device (e.g. tailnet URL)
#BLOG_EDITOR_SNS_LINKEDIN_EN_REDIRECT_URI=

# instagram-ko: no credentials needed (generate-only mode)
